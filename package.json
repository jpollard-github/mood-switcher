        "moodSwitcher.autoOpenResourcesOnModeSwitch": {
          "type": "boolean",
          "default": false,
          "description": "Open the configured resources right after changing moods."
        },
        "moodSwitcher.sessionHistoryLimit": {
          "type": "number",
          "default": 250,
          "description": "Maximum number of completed session records to retain for analytics."
