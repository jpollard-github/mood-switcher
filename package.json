{
  "name": "mood-driven-theme-switcher",
  "displayName": "Mood-Driven Theme Switcher",
  "description": "Switch VS Code themes, labels, and workflows based on your current working mood.",
  "version": "0.0.1",
  "publisher": "local-dev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jpollard-github/mood-switcher.git"
  },
  "homepage": "https://github.com/jpollard-github/mood-switcher",
  "files": [
    "dist/**",
    "resources/**",
    "README.md",
    "ROADMAP.md",
    "LICENSE"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Themes",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:moodSwitcher.sidebar",
    "onCommand:moodSwitcher.openDashboard",
    "onCommand:moodSwitcher.openDocs",
    "onCommand:moodSwitcher.activateSpecificMode",
    "onCommand:moodSwitcher.setSpecificModeAsDefault",
    "onCommand:moodSwitcher.openSpecificModeResources",
    "onCommand:moodSwitcher.startSpecificModeSession",
    "onCommand:moodSwitcher.openDashboardForMode",
    "onCommand:moodSwitcher.copyMoodSettings",
    "onCommand:moodSwitcher.previewModePreset",
    "onCommand:moodSwitcher.restoreOriginalWorkspaceState",
    "onCommand:moodSwitcher.resetWorkspaceToUserSettings",
    "onCommand:moodSwitcher.openModeSoundtrack",
    "onCommand:moodSwitcher.exportSessionHistory",
    "onCommand:moodSwitcher.importSessionHistory",
    "onCommand:moodSwitcher.validateModeCommands",
    "onCommand:moodSwitcher.openModeCommandPalette",
    "onCommand:moodSwitcher.runSuggestedCommand",
    "onCommand:moodSwitcher.openRankedMemoryDocs",
    "onCommand:moodSwitcher.showModeRitual",
    "onCommand:moodSwitcher.startBreakCycle",
    "onCommand:moodSwitcher.selectMode",
    "onCommand:moodSwitcher.startSession",
    "onCommand:moodSwitcher.stopSession",
    "onCommand:moodSwitcher.setWorkspaceDefaultMode",
    "onCommand:moodSwitcher.openModeResources"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "moodSwitcher",
          "title": "Mood Switcher",
          "icon": "resources/mood-switcher.svg"
        }
      ]
    },
    "views": {
      "moodSwitcher": [
        {
          "id": "moodSwitcher.sidebar",
          "name": "Modes"
        }
      ]
    },
    "commands": [
      {
        "command": "moodSwitcher.openDashboard",
        "title": "Mood Switcher: Open Dashboard"
      },
      {
        "command": "moodSwitcher.openDocs",
        "title": "Mood Switcher: Open Docs"
      },
      {
        "command": "moodSwitcher.activateSpecificMode",
        "title": "Mood Switcher: Activate Mode"
      },
      {
        "command": "moodSwitcher.setSpecificModeAsDefault",
        "title": "Mood Switcher: Make Mode Workspace Default"
      },
      {
        "command": "moodSwitcher.openSpecificModeResources",
        "title": "Mood Switcher: Open Resources For Mode"
      },
      {
        "command": "moodSwitcher.startSpecificModeSession",
        "title": "Mood Switcher: Start Session For Mode"
      },
      {
        "command": "moodSwitcher.openDashboardForMode",
        "title": "Mood Switcher: Open Dashboard For Mode"
      },
      {
        "command": "moodSwitcher.copyMoodSettings",
        "title": "Mood Switcher: Copy Mood Settings"
      },
      {
        "command": "moodSwitcher.previewModePreset",
        "title": "Mood Switcher: Preview Mode Preset"
      },
      {
        "command": "moodSwitcher.restoreOriginalWorkspaceState",
        "title": "Mood Switcher: Restore Original Workspace State"
      },
      {
        "command": "moodSwitcher.resetWorkspaceToUserSettings",
        "title": "Mood Switcher: Reset Workspace To User Settings"
      },
      {
        "command": "moodSwitcher.openModeSoundtrack",
        "title": "Mood Switcher: Open Mode Soundtrack"
      },
      {
        "command": "moodSwitcher.exportSessionHistory",
        "title": "Mood Switcher: Export Session History"
      },
      {
        "command": "moodSwitcher.importSessionHistory",
        "title": "Mood Switcher: Import Session History"
      },
      {
        "command": "moodSwitcher.validateModeCommands",
        "title": "Mood Switcher: Validate Mode Commands"
      },
      {
        "command": "moodSwitcher.openModeCommandPalette",
        "title": "Mood Switcher: Open Mode Command Palette"
      },
      {
        "command": "moodSwitcher.runSuggestedCommand",
        "title": "Mood Switcher: Run Suggested Command"
      },
      {
        "command": "moodSwitcher.openRankedMemoryDocs",
        "title": "Mood Switcher: Open Ranked Memory Docs"
      },
      {
        "command": "moodSwitcher.showModeRitual",
        "title": "Mood Switcher: Show Mode Ritual"
      },
      {
        "command": "moodSwitcher.startBreakCycle",
        "title": "Mood Switcher: Start Break Cycle"
      },
      {
        "command": "moodSwitcher.selectMode",
        "title": "Mood Switcher: Select Mode"
      },
      {
        "command": "moodSwitcher.startSession",
        "title": "Mood Switcher: Start Session"
      },
      {
        "command": "moodSwitcher.stopSession",
        "title": "Mood Switcher: Stop Session"
      },
      {
        "command": "moodSwitcher.setWorkspaceDefaultMode",
        "title": "Mood Switcher: Set Workspace Default Mode"
      },
      {
        "command": "moodSwitcher.clearWorkspaceDefaultMode",
        "title": "Mood Switcher: Clear Workspace Default Mode"
      },
      {
        "command": "moodSwitcher.openModeResources",
        "title": "Mood Switcher: Open Mode Resources"
      }
    ],
    "configuration": {
      "title": "Mood Switcher",
      "properties": {
        "moodSwitcher.enableThemeSwitching": {
          "type": "boolean",
          "default": true,
          "description": "Apply a mode-specific color theme when you switch moods."
        },
        "moodSwitcher.enableStatusBarLabel": {
          "type": "boolean",
          "default": true,
          "description": "Show the current mood and active session in the status bar."
        },
        "moodSwitcher.enableModePresets": {
          "type": "boolean",
          "default": true,
          "description": "Apply mode-specific workspace and editor layout presets when you switch moods."
        },
        "moodSwitcher.modeThemes": {
          "type": "object",
          "default": {
            "Deep Work": "Default Dark Modern",
            "Debugging Hell": "Default Dark+",
            "Writing Lodge": "Default Light Modern",
            "Arcade Mode": "Abyss",
            "Soft Focus": "Quiet Light",
            "Night Drive": "Monokai",
            "Ship It": "Kimbie Dark"
          },
          "description": "Maps each mood to a preferred VS Code color theme."
        },
        "moodSwitcher.modeColorCustomizations": {
          "type": "object",
          "default": {
            "Deep Work": {
              "statusBar.background": "#733018",
              "statusBar.foreground": "#fff7f0"
            },
            "Debugging Hell": {
              "statusBar.background": "#7d1f37",
              "statusBar.foreground": "#fff4f7"
            },
            "Writing Lodge": {
              "statusBar.background": "#8e6848",
              "statusBar.foreground": "#fffaf2"
            },
            "Arcade Mode": {
              "statusBar.background": "#006f63",
              "statusBar.foreground": "#effffb"
            },
            "Soft Focus": {
              "statusBar.background": "#5077a6",
              "statusBar.foreground": "#f8fbff"
            },
            "Night Drive": {
              "statusBar.background": "#0f5f6c",
              "statusBar.foreground": "#edfdfd"
            },
            "Ship It": {
              "statusBar.background": "#7b5b16",
              "statusBar.foreground": "#fffbea"
            }
          },
          "description": "Optional workbench.colorCustomizations to apply per mood. Intended for status bar color cues."
        },
        "moodSwitcher.modeSettings": {
          "type": "object",
          "default": {
            "Deep Work": {
              "editor.minimap.enabled": false,
              "editor.wordWrap": "off",
              "breadcrumbs.enabled": true,
              "workbench.editor.showTabs": "single",
              "zenMode.hideStatusBar": false
            },
            "Debugging Hell": {
              "debug.openDebug": "openOnSessionStart",
              "diffEditor.renderSideBySide": true,
              "editor.minimap.enabled": true,
              "problems.visibility": true,
              "workbench.panel.defaultLocation": "bottom"
            },
            "Writing Lodge": {
              "editor.wordWrap": "on",
              "editor.minimap.enabled": false,
              "editor.stickyScroll.enabled": false,
              "workbench.editor.showTabs": "single"
            },
            "Arcade Mode": {
              "editor.cursorBlinking": "phase",
              "editor.minimap.enabled": true,
              "terminal.integrated.defaultLocation": "editor"
            },
            "Soft Focus": {
              "editor.minimap.enabled": false,
              "editor.wordWrap": "bounded",
              "editor.renderWhitespace": "selection",
              "workbench.editor.showTabs": "single"
            },
            "Night Drive": {
              "editor.cursorSmoothCaretAnimation": "on",
              "editor.minimap.enabled": false,
              "terminal.integrated.defaultLocation": "editor",
              "workbench.panel.defaultLocation": "right"
            },
            "Ship It": {
              "files.autoSave": "afterDelay",
              "files.autoSaveDelay": 1000,
              "problems.visibility": true,
              "scm.defaultViewMode": "tree",
              "workbench.panel.defaultLocation": "bottom"
            }
          },
          "description": "Workspace and editor settings to apply for each mood."
        },
        "moodSwitcher.modeCommands": {
          "type": "object",
          "default": {
            "Deep Work": {
              "onActivate": [
                {
                  "command": "workbench.action.focusActiveEditorGroup"
                }
              ]
            },
            "Debugging Hell": {
              "onActivate": [
                {
                  "command": "workbench.action.problems.focus"
                }
              ]
            },
            "Writing Lodge": {
              "onActivate": [
                {
                  "command": "workbench.action.focusActiveEditorGroup"
                }
              ]
            },
            "Ship It": {
              "onActivate": [
                {
                  "command": "workbench.view.scm"
                }
              ]
            }
          },
          "description": "Optional VS Code commands to run per mood. Supports onActivate, onStartSession, and onStopSession hooks."
        },
        "moodSwitcher.modeSuggestedCommands": {
          "type": "object",
          "default": {
            "Deep Work": [
              {
                "group": "Focus",
                "label": "Focus Active Editor",
                "description": "Bring attention back to the main editor",
                "command": "workbench.action.focusActiveEditorGroup"
              },
              {
                "group": "Focus",
                "label": "Toggle Zen Mode",
                "description": "Reduce distractions quickly",
                "command": "workbench.action.toggleZenMode"
              },
              {
                "group": "Mood Switcher",
                "label": "Open Ranked Memory Docs",
                "description": "Open the best matching project context docs",
                "command": "moodSwitcher.openRankedMemoryDocs"
              }
            ],
            "Debugging Hell": [
              {
                "group": "Debug",
                "label": "Focus Problems",
                "description": "Jump to problems and errors",
                "command": "workbench.action.problems.focus"
              },
              {
                "group": "Debug",
                "label": "Open Run and Debug",
                "description": "Open the debug view",
                "command": "workbench.view.debug"
              },
              {
                "group": "Mood Switcher",
                "label": "Open Ranked Memory Docs",
                "description": "Open debug notes and related docs",
                "command": "moodSwitcher.openRankedMemoryDocs"
              }
            ],
            "Writing Lodge": [
              {
                "group": "Writing",
                "label": "Show Markdown Preview",
                "description": "Preview the current markdown file",
                "command": "markdown.showPreview"
              },
              {
                "group": "Writing",
                "label": "Toggle Word Wrap",
                "description": "Adjust the writing view quickly",
                "command": "editor.action.toggleWordWrap"
              },
              {
                "group": "Mood Switcher",
                "label": "Show Mode Ritual",
                "description": "Review the writing ritual again",
                "command": "moodSwitcher.showModeRitual"
              }
            ],
            "Arcade Mode": [
              {
                "group": "Build",
                "label": "Toggle Terminal",
                "description": "Keep feedback loops close",
                "command": "workbench.action.terminal.toggleTerminal"
              },
              {
                "group": "Build",
                "label": "Save All",
                "description": "Persist the current iteration",
                "command": "workbench.action.files.saveAll"
              },
              {
                "group": "Mood Switcher",
                "label": "Open Mode Soundtrack",
                "description": "Choose a playlist source for this mood",
                "command": "moodSwitcher.openModeSoundtrack"
              }
            ],
            "Soft Focus": [
              {
                "group": "Focus",
                "label": "Quick Open",
                "description": "Jump gently to the next file",
                "command": "workbench.action.quickOpen"
              },
              {
                "group": "Focus",
                "label": "Save",
                "description": "Bank progress with minimal friction",
                "command": "workbench.action.files.save"
              },
              {
                "group": "Mood Switcher",
                "label": "Show Mode Ritual",
                "description": "Review the current small-step ritual",
                "command": "moodSwitcher.showModeRitual"
              }
            ],
            "Night Drive": [
              {
                "group": "Flow",
                "label": "Focus Terminal",
                "description": "Bring the terminal to the foreground",
                "command": "workbench.action.terminal.focus"
              },
              {
                "group": "Flow",
                "label": "Run Task",
                "description": "Kick off a task from the command palette",
                "command": "workbench.action.tasks.runTask"
              },
              {
                "group": "Mood Switcher",
                "label": "Open Mode Soundtrack",
                "description": "Choose a playlist source for this mood",
                "command": "moodSwitcher.openModeSoundtrack"
              }
            ],
            "Ship It": [
              {
                "group": "Ship",
                "label": "Open Source Control",
                "description": "Jump into SCM state",
                "command": "workbench.view.scm"
              },
              {
                "group": "Ship",
                "label": "Run Task",
                "description": "Kick off release or validation tasks",
                "command": "workbench.action.tasks.runTask"
              },
              {
                "group": "Mood Switcher",
                "label": "Open Ranked Memory Docs",
                "description": "Open release notes and checklist context",
                "command": "moodSwitcher.openRankedMemoryDocs"
              }
            ]
          },
          "description": "Suggested built-in and Mood Switcher commands shown in the mode-aware command palette."
        },
        "moodSwitcher.modeTimers": {
          "type": "object",
          "default": {
            "Deep Work": {
              "durationMinutes": 50
            },
            "Debugging Hell": {
              "durationMinutes": 30
            },
            "Writing Lodge": {
              "durationMinutes": 45
            },
            "Arcade Mode": {
              "durationMinutes": 25
            },
            "Soft Focus": {
              "durationMinutes": 20
            },
            "Night Drive": {
              "durationMinutes": 60
            },
            "Ship It": {
              "durationMinutes": 20
            }
          },
          "description": "Optional per-mode timer defaults in minutes for sessions."
        },
        "moodSwitcher.modeRituals": {
          "type": "object",
          "default": {
            "Deep Work": [
              "Close distractions and focus the main editor.",
              "Skim the current task or TODO before you begin."
            ],
            "Debugging Hell": [
              "Open the failing test or log first.",
              "Write down your current hypothesis before chasing branches."
            ],
            "Writing Lodge": [
              "Open the target doc and outline the next section.",
              "Decide whether this session is drafting, editing, or pruning."
            ],
            "Arcade Mode": [
              "Open the UI surface you want to iterate on.",
              "Keep the terminal visible for fast feedback."
            ],
            "Soft Focus": [
              "Pick one small next action.",
              "Give yourself permission to stay narrow and gentle."
            ],
            "Night Drive": [
              "Open the code, terminal, and notes you want for the long haul.",
              "Decide what done looks like before the session drifts."
            ],
            "Ship It": [
              "Check problems, tests, and release notes first.",
              "Confirm what needs to ship before polishing extras."
            ]
          },
          "description": "Optional checklist-style rituals shown before a timed session begins."
        },
        "moodSwitcher.modeSoundtracks": {
          "type": "object",
          "default": {
            "Deep Work": {
              "label": "Deep Focus Playlist",
              "youtubeUrl": "https://music.youtube.com/search?q=deep%20focus%20instrumental",
              "spotifyUrl": "https://open.spotify.com/search/deep%20focus%20instrumental"
            },
            "Debugging Hell": {
              "label": "Debug Flow Mix",
              "youtubeUrl": "https://music.youtube.com/search?q=dark%20synth%20coding%20playlist",
              "spotifyUrl": "https://open.spotify.com/search/dark%20synth%20coding%20playlist"
            },
            "Writing Lodge": {
              "label": "Writing Ambience",
              "youtubeUrl": "https://music.youtube.com/search?q=writing%20ambient%20playlist",
              "spotifyUrl": "https://open.spotify.com/search/writing%20ambient%20playlist"
            },
            "Arcade Mode": {
              "label": "Arcade Energy",
              "youtubeUrl": "https://music.youtube.com/search?q=arcade%20synthwave%20playlist",
              "spotifyUrl": "https://open.spotify.com/search/arcade%20synthwave%20playlist"
            },
            "Soft Focus": {
              "label": "Gentle Focus",
              "youtubeUrl": "https://music.youtube.com/search?q=soft%20focus%20playlist",
              "spotifyUrl": "https://open.spotify.com/search/soft%20focus%20playlist"
            },
            "Night Drive": {
              "label": "Night Drive",
              "youtubeUrl": "https://music.youtube.com/search?q=night%20drive%20synthwave",
              "spotifyUrl": "https://open.spotify.com/search/night%20drive%20synthwave"
            },
            "Ship It": {
              "label": "Shipping Momentum",
              "youtubeUrl": "https://music.youtube.com/search?q=focus%20hype%20playlist",
              "spotifyUrl": "https://open.spotify.com/search/focus%20hype%20playlist"
            }
          },
          "description": "Optional per-mode soundtrack options. Supports YouTube, Spotify, a custom playlist URL, and a legacy url fallback."
        },
        "moodSwitcher.modeTimerCycles": {
          "type": "object",
          "default": {
            "Deep Work": {
              "breakMinutes": 10,
              "offerNextFocusBlock": true
            },
            "Debugging Hell": {
              "breakMinutes": 5,
              "offerNextFocusBlock": true
            },
            "Writing Lodge": {
              "breakMinutes": 10,
              "offerNextFocusBlock": true
            },
            "Arcade Mode": {
              "breakMinutes": 5,
              "offerNextFocusBlock": true
            },
            "Soft Focus": {
              "breakMinutes": 5,
              "offerNextFocusBlock": false
            },
            "Night Drive": {
              "breakMinutes": 15,
              "offerNextFocusBlock": true
            },
            "Ship It": {
              "breakMinutes": 5,
              "offerNextFocusBlock": true
            }
          },
          "description": "Optional break-cycle settings used when a timed session ends."
        },
        "moodSwitcher.modeResourceGlobs": {
          "type": "object",
          "default": {
            "Deep Work": [
              "README.md",
              "docs/**",
              "src/**"
            ],
            "Debugging Hell": [
              "**/*test*",
              "**/*spec*",
              "logs/**",
              ".vscode/launch.json"
            ],
            "Writing Lodge": [
              "README.md",
              "docs/**",
              "**/*.md"
            ],
            "Arcade Mode": [
              "src/**",
              "assets/**",
              "public/**"
            ],
            "Soft Focus": [
              "README.md",
              "src/**"
            ],
            "Night Drive": [
              "src/**",
              ".github/**",
              ".vscode/**"
            ],
            "Ship It": [
              "package.json",
              "CHANGELOG.md",
              ".github/**",
              ".vscode/**"
            ]
          },
          "description": "Glob patterns the extension uses when opening mode-related project files."
        },
        "moodSwitcher.modeMemoryFiles": {
          "type": "object",
          "default": {
            "Deep Work": [
              ".codex/project-memory.md",
              "docs/project-memory.md"
            ],
            "Debugging Hell": [
              ".codex/debug-notes.md",
              "docs/debug-notes.md"
            ],
            "Ship It": [
              ".codex/release-checklist.md",
              "docs/release-checklist.md"
            ]
          },
          "description": "Optional project memory files to open for selected moods."
        },
        "moodSwitcher.enableSmartProjectMemory": {
          "type": "boolean",
          "default": true,
          "description": "Discover likely .codex, docs, and repo memory files based on the active mood."
        },
        "moodSwitcher.modeMemoryKeywords": {
