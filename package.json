        "moodSwitcher.dashboardOpensOnStartup": {
          "type": "boolean",
          "default": false,
          "description": "Open the Mood Switcher dashboard when the workspace starts."
        }
      }
    },
    "menus": {
      "view/item/context": [
        {
          "command": "moodSwitcher.activateSpecificMode",
          "when": "view == moodSwitcher.sidebar && viewItem == mood",
          "group": "inline@1"
        },
        {
          "command": "moodSwitcher.openSpecificModeResources",
          "when": "view == moodSwitcher.sidebar && viewItem == mood",
          "group": "inline@2"
        },
        {
          "command": "moodSwitcher.startSpecificModeSession",
          "when": "view == moodSwitcher.sidebar && viewItem == mood",
          "group": "navigation@1"
        },
        {
          "command": "moodSwitcher.setSpecificModeAsDefault",
          "when": "view == moodSwitcher.sidebar && viewItem == mood",
          "group": "navigation@2"
        },
        {
          "command": "moodSwitcher.openDashboardForMode",
          "when": "view == moodSwitcher.sidebar && viewItem == mood",
          "group": "navigation@3"
        },
        {
          "command": "moodSwitcher.previewModePreset",
          "when": "view == moodSwitcher.sidebar && viewItem == mood",
          "group": "navigation@4"
        },
        {
          "command": "moodSwitcher.copyMoodSettings",
          "when": "view == moodSwitcher.sidebar && viewItem == mood",
          "group": "navigation@5"
        }
      ]
    }
  },
  "scripts": {
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "build": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run lint && npm run build",
    "package:vsix": "vsce package --out ./vsix/mood-driven-theme-switcher-${npm_package_version}.vsix",
    "package:vsix:no-deps": "vsce package --out ./vsix/mood-driven-theme-switcher-${npm_package_version}.vsix --no-dependencies"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true,
      "es2022": true
    },
    "parser": "@typescript-eslint/parser",
    "parserOptions": {
      "sourceType": "module",
      "ecmaVersion": 2022
    },
    "plugins": [
      "@typescript-eslint"
    ],
    "extends": [
      "eslint:recommended",
      "plugin:@typescript-eslint/recommended"
    ],
    "ignorePatterns": [
      "dist",
      "node_modules",
      "vsix"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.34.1",
    "@typescript-eslint/parser": "^8.34.1",
    "@types/node": "^20.14.10",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.6.2",
    "eslint": "^8.57.1",
    "typescript": "^5.5.4"
  }
}
