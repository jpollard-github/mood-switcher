        "moodSwitcher.modeMemoryProfiles": {
          "type": "object",
          "default": {
            "Deep Work": {
              "preferredDirectories": [
                ".codex",
                "docs",
                "src"
              ],
              "boostFilenames": [
                "project-memory",
                "overview",
